# vllm
VLLM_TORCH_BACKEND=auto
CUDA_VISIBLE_DEVICES=0
LLAMA_SERVER_HOST= http://localhost

# llm keys
OPENAI_API_KEY=
GOOGLE_API_KEY=
HF_TOKEN=

GEMINI_FLASH_INPUT_PRICE=0
GEMINI_FLASH_OUTPUT_PRICE=0

# UI/API
VITE_API_BASE_URL=http://localhost:8000
CORS_ALLOWED_ORIGINS = "http://localhost:3000,http://127.0.0.1:3000"

# DB
POSTGRES_HOST=
PGB_BIND_HOST=
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_pass
POSTGRES_DB=postgres
POSTGRES_PORT=

LANGFUSE_DB=langfuse
LANGFUSE_DB_USER=langfuse
LANGFUSE_DB_PASSWORD=langfuse_pass

APP_DB=app
APP_DB_NAME=app
APP_DB_USER=app
APP_DB_PASSWORD=app_pass
# APP_DB_HOST/APP_DB_PORT are what get_db_url() actually reads. Host-process runs
# (make api/worker, src.eval.run) use these to reach the published pgbouncer port.
# Containerized services override them to pgbouncer:6432 via x-app-env in compose,
# so setting localhost here does not affect the compose stack.
APP_DB_HOST=localhost
APP_DB_PORT=6432
# PGB_APP_DB_* are consumed only by compose (pgbouncer port publish, Grafana datasource).
PGB_APP_DB_HOST=pgbouncer
PGB_APP_DB_PORT=6432

# Redis
REDIS_APP_HOST=127.0.0.1
REDIS_APP_PORT=6379
REDIS_BROKER_HOST=127.0.0.1
REDIS_BROKER_PORT=6380
REDIS_APP_DB=0
REDIS_BROKER_DB=0
REDIS_PASSWORD=
CHAT_HISTORY_TTL=1200

# JWT
JWT_SECRET=
JWT_EXPIRATION_TIME=600m
JWT_REFRESH_TIME=7d
COOKIE_SECURE=false

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Garage S3 credentials - generated by garage_bootstrap.sh
# Source this file or use with your S3 client.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL=http://127.0.0.1:3900
AWS_DEFAULT_REGION=garage
S3_BUCKET=pdfs
S3_RAW_BUCKET=pdfs
S3_DOCLING_BUCKET=docling
S3_RENDERED_BUCKET=rendered
S3_CHUNKS_BUCKET=chunks


# Chunking config
CHUNKING_TOKENIZER_MODEL=BAAI/bge-m3
CHUNKING_MAX_TOKENS=900
CHUNKING_MIN_TOKENS=100
CHUNKING_MAX_MERGE_MULTIPLIER=3.0
DOCLING_GENERATE_PICTURE_IMAGES=true

# Retrieval config
VECTOR_SEARCH_TOP_K=50
KEYWORD_SEARCH_TOP_K=50
FUSE_RRF_K=20
FUSE_RRF_FINAL_TOP_K=50
FUSE_RRF_VECTOR_WEIGHT=0.4
FUSE_RRF_KEYWORD_WEIGHT=0.6
ENTITY_SIMILARITY_THRESHOLD=0.5

EMBED_MODEL_ID=BAAI/bge-m3

# Qdrant config
QDRANT_HOST=127.0.0.1
QDRANT_GRPC_PORT=6334
QDRANT_PORT=6333

# OpenSearch config
OPENSEARCH_BIND_HOST=127.0.0.1
OPENSEARCH_HTTP_PORT=9200
OPENSEARCH_MANAGEMENT_PORT=9600
OPENSEARCH_DASHBOARDS_BIND_HOST=127.0.0.1
OPENSEARCH_DASHBOARDS_PORT=5601

# Garage config
GARAGE_BIND_HOST=127.0.0.1
GARAGE_S3_PORT=3900
GARAGE_ADMIN_PORT=3901
GARAGE_METRICS_PORT=3902
GARAGE_RPC_PORT=3903


# Celery config
CELERY_VISIBILITY_TIMEOUT_SECONDS=2400
CELERY_TASK_SOFT_TIME_LIMIT_SECONDS=900
CELERY_TASK_TIME_LIMIT_SECONDS=1200
INGEST_MAX_ATTEMPTS=2

# Chat config
CHAT_TAIL_TTL=1800
CHAT_TAIL_MAX_MESSAGES=50

# Reranker (TEI cross-encoder)
RERANKER_ENABLED=true
RERANKER_BASE_URL=http://localhost:8080
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3
RERANKER_TIMEOUT_SECONDS=10.0
RERANKER_TOP_K=8
RERANKER_MAX_INPUT=50
HF_TOKEN=


# QUERY_ROUTER_MODEL=qwen3-8b
TABLE_SUMMARIZER_MODEL=qwen3-8b
TABLE_SUMMARIZER_ENABLED=False

EMBEDDING_PROVIDER=tei
TEI_EMBED_URL=http://localhost:8081

EVAL_USER_ID=d2481864-7eaf-4548-b515-34a14d4ec7b4

# Langfuse
LANGFUSE_BIND_HOST=127.0.0.1
LANGFUSE_PORT=3003
LANGFUSE_URL=http://localhost:3003

# ClickHouse (used by Langfuse)
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=

# Langfuse secrets
# Generate: openssl rand -base64 32
LANGFUSE_NEXTAUTH_SECRET=
# Generate: openssl rand -base64 24
LANGFUSE_SALT=
# Generate: openssl rand -hex 32  (must be exactly 64 hex chars)
LANGFUSE_ENCRYPTION_KEY=

# Langfuse S3 (Garage): copy from infra/docker/garage/secrets/garage_s3_creds after garage-bootstrap
LANGFUSE_S3_ACCESS_KEY_ID=
LANGFUSE_S3_SECRET_ACCESS_KEY=

# Langfuse first-boot seed — auto-creates org/project/user if all three INIT_USER_* are set
# Leave blank to skip and register manually at http://localhost:3000
LANGFUSE_INIT_ORG_ID=
LANGFUSE_INIT_ORG_NAME=
LANGFUSE_INIT_PROJECT_ID=
LANGFUSE_INIT_PROJECT_NAME=
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=
LANGFUSE_INIT_PROJECT_SECRET_KEY=
LANGFUSE_INIT_USER_EMAIL=
LANGFUSE_INIT_USER_NAME=
LANGFUSE_INIT_USER_PASSWORD=

LANGFUSE_ENABLED=true
LANGFUSE_HOST=http://langfuse-web:3000
LANGFUSE_PUBLIC_KEY=<value of LANGFUSE_INIT_PROJECT_PUBLIC_KEY>
LANGFUSE_SECRET_KEY=<value of LANGFUSE_INIT_PROJECT_SECRET_KEY>


# UI/API
API_HOST=api
API_PORT=8000

# Chunking config
DOCLING_PICTURE_VLM_MODEL=HuggingFaceTB/SmolVLM-500M-Instruct

# OpenSearch config
OPENSEARCH_HOST=127.0.0.1
OPENSEARCH_PUBLISH_HOST=127.0.0.1

# Secrets (uid/gid for bootstrap containers)
SECRETS_UID=1002
SECRETS_GID=1002

# Injection scanning
INJECTION_SCAN_USER_INPUT=true
INJECTION_SCAN_CHUNKS=true

# Agent loop
AGENT_LOOP_ENABLED=True
AGENT_TOOL_MODEL=gpt-5-mini

# Embedder (TEI)
EMBEDDER_BASE_URL=http://localhost:8082
EMBEDDER_MODEL_NAME=BAAI/bge-m3

CONVERSATION_NAMING_ENABLED=true

# Grafana
GRAFANA_USER=admin
GRAFANA_PASS=
GRAFANA_PORT=3004
GRAFANA_BIND_HOST=127.0.0.1

# Prometheus
PROMETHEUS_PORT=9090
PROMETHEUS_BIND_HOST=127.0.0.1

# Elasticsearch
ES_BIND_HOST=127.0.0.1
ES_BIND_PORT=9201
ES_HOST=elasticsearch
ES_PORT=9200

# Fluent Bit
FLUENT_BIT_BIND_HOST=127.0.0.1
FLUENT_BIT_PORT=24224
LOG_FILE=
LOG_FILE_DIR=

# Prefork pool size for the chat worker. Defaults to Celery's own default
# (CPU count) if unset — cap this to fit the worker-chat container's mem_limit.
CELERY_CHAT_WORKER_CONCURRENCY=4
