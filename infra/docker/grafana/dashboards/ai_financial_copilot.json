{
  "title": "AI Financial Copilot",
  "uid": "ai-financial-copilot",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "job",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(up, job)",
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "refresh": 2,
        "label": "Job"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "HTTP API",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 2,
      "title": "Request Rate (rps)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 1, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m])) by (endpoint)",
          "legendFormat": "{{endpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 3,
      "title": "Error Rate (5xx)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 1, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..\"}[1m])) by (endpoint)",
          "legendFormat": "{{endpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "fixedColor": "red", "mode": "fixed" } }
      }
    },
    {
      "id": 4,
      "title": "HTTP Latency p50/p95/p99 (s)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 1, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[1m])) by (le, endpoint))",
          "legendFormat": "p50 {{endpoint}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[1m])) by (le, endpoint))",
          "legendFormat": "p95 {{endpoint}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[1m])) by (le, endpoint))",
          "legendFormat": "p99 {{endpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 10,
      "type": "row",
      "title": "Chat Pipeline",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 11,
      "title": "Router Decisions",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 9, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(query_router_decisions_total[5m])) by (decision)",
          "legendFormat": "{{decision}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 12,
      "title": "Pipeline Errors by Stage",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 9, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(chat_pipeline_errors_total[5m])) by (stage)",
          "legendFormat": "{{stage}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "fixedColor": "orange", "mode": "fixed" } }
      }
    },
    {
      "id": 13,
      "title": "Guardrail Blocks",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 9, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(guardrail_blocks_total[5m])) by (type)",
          "legendFormat": "{{type}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 20,
      "type": "row",
      "title": "Agentic RAG",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 21,
      "title": "Agent Loop Iterations (distribution)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 17, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(agent_loop_iterations_bucket[10m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(agent_loop_iterations_bucket[10m])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 22,
      "title": "Tool Calls Rate",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 17, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(agent_tool_calls_total[5m])) by (tool, status)",
          "legendFormat": "{{tool}} [{{status}}]"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 23,
      "title": "Tool Duration p95 (s)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 17, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(agent_tool_duration_seconds_bucket[5m])) by (le, tool))",
          "legendFormat": "p95 {{tool}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 24,
      "title": "RAG Retrieval Latency p95 (s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(rag_retrieval_duration_seconds_bucket[5m])) by (le, stage))",
          "legendFormat": "p95 {{stage}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 25,
      "title": "Chunks Retrieved (median)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 24, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(rag_chunks_retrieved_bucket[5m])) by (le, retriever))",
          "legendFormat": "p50 {{retriever}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 26,
      "title": "Citations per Response (median)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 24, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(rag_citations_per_response_bucket[10m])) by (le))",
          "legendFormat": "p50 citations"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 30,
      "type": "row",
      "title": "LLM Cost & Tokens",
      "gridPos": { "x": 0, "y": 31, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 31,
      "title": "Token Rate (tokens/s) by Model",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 32, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(llm_tokens_total[5m])) by (direction, model)",
          "legendFormat": "{{direction}} {{model}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 32,
      "title": "Cost Rate (USD/s) by Model",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 32, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(llm_cost_usd_total[5m])) by (model)",
          "legendFormat": "{{model}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD" }
      }
    },
    {
      "id": 33,
      "title": "Cache Hit Tokens Rate",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 32, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(llm_cache_hit_tokens_total[5m])) by (model)",
          "legendFormat": "{{model}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 40,
      "type": "row",
      "title": "Ingestion Pipeline",
      "gridPos": { "x": 0, "y": 39, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 41,
      "title": "Documents Processed",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 40, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(ingestion_documents_total[10m])) by (status)",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 42,
      "title": "Ingestion Stage Duration p95 (s)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 40, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(ingestion_stage_duration_seconds_bucket[10m])) by (le, stage))",
          "legendFormat": "p95 {{stage}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 43,
      "title": "Chunks per Document (median)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 40, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(ingestion_chunks_per_document_bucket[10m])) by (le))",
          "legendFormat": "p50"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 50,
      "type": "row",
      "title": "Celery Workers",
      "gridPos": { "x": 0, "y": 47, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 51,
      "title": "Task Rate by State",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 48, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(celery_tasks_total[5m])) by (task_name, state)",
          "legendFormat": "{{task_name}} [{{state}}]"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 52,
      "title": "Task Duration p95 (s)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 48, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(celery_task_duration_seconds_bucket[5m])) by (le, task_name))",
          "legendFormat": "p95 {{task_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 53,
      "title": "Queue Depth",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 48, "w": 8, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "celery_queue_length",
          "legendFormat": "{{queue_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    }
  ]
}
