{
  "title": "Agentic RAG",
  "uid": "agentic-rag",
  "description": "ML / product engineer view: retrieval latency, agent loop health, router decisions, and answer quality signals.",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Retrieval Pipeline",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 2,
      "title": "Retrieval Latency p95 by Stage (s)",
      "type": "timeseries",
      "description": "Identify which retrieval stage is the bottleneck: embed / hybrid_retrieve / rerank.",
      "gridPos": { "x": 0, "y": 1, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(rag_retrieval_duration_seconds_bucket[5m])) by (le, stage))",
          "legendFormat": "p95 {{stage}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 5 } }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "id": 3,
      "title": "Chunks Retrieved (p50 / p95) by Retriever",
      "type": "timeseries",
      "description": "Abnormally low = recall problem; abnormally high = reranker overload.",
      "gridPos": { "x": 8, "y": 1, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(rag_chunks_retrieved_bucket[5m])) by (le, retriever))",
          "legendFormat": "p50 {{retriever}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(rag_chunks_retrieved_bucket[5m])) by (le, retriever))",
          "legendFormat": "p95 {{retriever}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 5 } }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "id": 4,
      "title": "Context Tokens (p50 / p95)",
      "type": "timeseries",
      "description": "Proximity to context window limits; prompt cost driver.",
      "gridPos": { "x": 16, "y": 1, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(rag_context_tokens_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(rag_context_tokens_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 5 } }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "id": 5,
      "title": "Citations per Response (p50 / p95)",
      "type": "timeseries",
      "description": "Zero-citation responses = retrieval miss or citation parser failure.",
      "gridPos": { "x": 0, "y": 9, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(rag_citations_per_response_bucket[10m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(rag_citations_per_response_bucket[10m])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 5 } }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "id": 6,
      "type": "row",
      "title": "Agent Loop",
      "gridPos": { "x": 0, "y": 17, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 7,
      "title": "Agent Loop Iterations (p50 / p95)",
      "type": "timeseries",
      "description": "Runaway loops (>5 iterations) signal tool-call failures or prompt issues.",
      "gridPos": { "x": 0, "y": 18, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(agent_loop_iterations_bucket[10m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(agent_loop_iterations_bucket[10m])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0, "custom": { "lineWidth": 2, "fillOpacity": 5 } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "p95" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "id": 8,
      "title": "Tool Call Rate by Tool & Status",
      "type": "timeseries",
      "description": "Which tools are called most and which are error-prone.",
      "gridPos": { "x": 8, "y": 18, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(agent_tool_calls_total[5m])) by (tool, status)",
          "legendFormat": "{{tool}} [{{status}}]"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 5 } },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*error.*" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "id": 9,
      "title": "Tool Duration p95 by Tool (s)",
      "type": "timeseries",
      "description": "Which tools are slow — latency per tool call.",
      "gridPos": { "x": 16, "y": 18, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(agent_tool_duration_seconds_bucket[5m])) by (le, tool))",
          "legendFormat": "p95 {{tool}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 5 } }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "id": 10,
      "type": "row",
      "title": "Router & Guardrails",
      "gridPos": { "x": 0, "y": 26, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 11,
      "title": "Router Decision Split",
      "type": "timeseries",
      "description": "direct_answer share creeping up = router misfiring; out_of_scope spike = coverage gap.",
      "gridPos": { "x": 0, "y": 27, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(query_router_decisions_total[5m])) by (decision)",
          "legendFormat": "{{decision}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 5 } }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "id": 12,
      "title": "Guardrail Blocks by Type",
      "type": "timeseries",
      "description": "Injection attempt rate and prompt abuse patterns.",
      "gridPos": { "x": 8, "y": 27, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(guardrail_blocks_total[5m])) by (type)",
          "legendFormat": "{{type}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*injection.*" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "id": 13,
      "title": "Pipeline Errors by Stage",
      "type": "timeseries",
      "description": "Which pipeline stage is most fragile.",
      "gridPos": { "x": 16, "y": 27, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(chat_pipeline_errors_total[5m])) by (stage)",
          "legendFormat": "{{stage}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": [
          {
            "matcher": { "id": "byValue", "options": { "reducer": "lastNotNull", "op": "gt", "value": 0 } },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "id": 14,
      "type": "row",
      "title": "Quality Drill-Down (PostgreSQL)",
      "gridPos": { "x": 0, "y": 35, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 15,
      "title": "Per-Request Stage Breakdown (slowest in range)",
      "type": "table",
      "description": "Outlier drill-down: the slowest requests in the dashboard time range. Not possible from aggregate histograms — find the specific requests where a stage blew up.",
      "gridPos": { "x": 0, "y": 36, "w": 12, "h": 10 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT m.id, m.created_at, (m.trace->>'total_time')::numeric AS total_time_s, m.trace->'stage_times' AS stage_times FROM messages m WHERE m.role = 'assistant' AND m.trace ? 'total_time' AND $__timeFilter(m.created_at) ORDER BY (m.trace->>'total_time')::numeric DESC NULLS LAST LIMIT 50;"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "total_time_s" }, "properties": [{ "id": "unit", "value": "s" }] },
          { "matcher": { "id": "byName", "options": "created_at" }, "properties": [{ "id": "unit", "value": "dateTimeAsIso" }] }
        ]
      },
      "options": { "sortBy": [{ "displayName": "total_time_s", "desc": true }] }
    },
    {
      "id": 16,
      "title": "Response Quality — Thumbs Down Rate (hourly)",
      "type": "timeseries",
      "description": "Only user-perceived quality signal — catches fast-but-wrong regressions.",
      "gridPos": { "x": 12, "y": 36, "w": 12, "h": 10 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT date_trunc('hour', created_at) AS time, count(*) FILTER (WHERE rating = 'down')::float / NULLIF(count(*), 0) AS thumbs_down_rate FROM message_feedback GROUP BY 1 ORDER BY 1;"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 17,
      "title": "Router LLM Overhead vs Chat Latency",
      "type": "timeseries",
      "description": "Cost of routing sub-call vs main response — validate the router is worth the latency.",
      "gridPos": { "x": 0, "y": 46, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT date_trunc('minute', created_at) AS time, request_type, avg(latency_ms) AS avg_latency_ms FROM llm_requests WHERE request_type IN ('router', 'chat') GROUP BY 1, 2 ORDER BY 1;"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 2, "fillOpacity": 5 } }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    }
  ]
}
