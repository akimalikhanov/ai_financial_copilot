{
  "title": "Logs Scratchpad",
  "uid": "logs-scratchpad",
  "tags": ["logs"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Log Stream",
      "type": "logs",
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch" },
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "elasticsearch", "uid": "elasticsearch" },
          "query": "",
          "metrics": [{ "id": "1", "type": "logs" }],
          "bucketAggs": [],
          "timeField": "timestamp"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error count over time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch" },
      "fieldConfig": {
        "defaults": { "color": { "fixedColor": "red", "mode": "fixed" } }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "elasticsearch", "uid": "elasticsearch" },
          "query": "level:ERROR",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [
            {
              "id": "2",
              "type": "date_histogram",
              "field": "timestamp",
              "settings": { "interval": "auto", "min_doc_count": "0" }
            }
          ],
          "timeField": "timestamp"
        }
      ]
    },
    {
      "id": 3,
      "title": "Log volume by level",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "elasticsearch", "uid": "elasticsearch" },
          "query": "",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [
            {
              "id": "2",
              "type": "terms",
              "field": "level",
              "settings": { "size": "10", "order": "desc", "orderBy": "_count", "min_doc_count": "1" }
            },
            {
              "id": "3",
              "type": "date_histogram",
              "field": "timestamp",
              "settings": { "interval": "auto", "min_doc_count": "1" }
            }
          ],
          "timeField": "timestamp"
        }
      ]
    }
  ]
}
