{
  "title": "Worker Health",
  "uid": "worker-health",
  "description": "Celery throughput, failures, queue backlog, and ingestion pipeline health (Prometheus + PostgreSQL + logs).",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "task",
        "label": "Task",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(celery_tasks_total, task_name)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Celery Throughput & Failures",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 2,
      "title": "Task Throughput (success/s)",
      "type": "timeseries",
      "description": "Normal processing rate baseline — success rate per task.",
      "gridPos": { "x": 0, "y": 1, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(celery_tasks_total{state=\"success\",task_name=~\"$task\"}[5m])) by (task_name)",
          "legendFormat": "{{task_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 5 } }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "id": 3,
      "title": "Task Failure / Retry Rate",
      "type": "timeseries",
      "description": "First signal of worker degradation.",
      "gridPos": { "x": 8, "y": 1, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(celery_tasks_total{state=~\"failure|retry\",task_name=~\"$task\"}[5m])) by (task_name, state)",
          "legendFormat": "{{task_name}} [{{state}}]"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*failure.*" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*retry.*" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "id": 4,
      "title": "Queue Depth",
      "type": "timeseries",
      "description": "Backlog growth = workers can't keep up. Approximate (LLEN omits in-flight tasks).",
      "gridPos": { "x": 16, "y": 1, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "max(celery_queue_length) by (queue_name)",
          "legendFormat": "{{queue_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0, "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "id": 5,
      "title": "Task p95 Duration (s)",
      "type": "timeseries",
      "description": "Slow task detection before users complain.",
      "gridPos": { "x": 0, "y": 9, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(celery_task_duration_seconds_bucket{task_name=~\"$task\"}[5m])) by (le, task_name))",
          "legendFormat": "p95 {{task_name}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 5 } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "id": 6,
      "type": "row",
      "title": "Ingestion Pipeline",
      "gridPos": { "x": 0, "y": 17, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 7,
      "title": "Ingestion Stage Latency p95 (s)",
      "type": "timeseries",
      "description": "Pinpoint which stage (parse / chunk / embed / upsert) is the bottleneck.",
      "gridPos": { "x": 0, "y": 18, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(increase(ingestion_stage_duration_seconds_bucket[$__range])) by (le, stage))",
          "legendFormat": "p95 {{stage}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 5 } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "id": 8,
      "title": "Chunks per Document (p50 / p95)",
      "type": "timeseries",
      "description": "Outlier documents that generate 10x normal chunks and slow the queue.",
      "gridPos": { "x": 8, "y": 18, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(increase(ingestion_chunks_per_document_bucket[$__range])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(increase(ingestion_chunks_per_document_bucket[$__range])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 5 } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "id": 9,
      "title": "Documents by Status (rate)",
      "type": "timeseries",
      "description": "Success/failure ratio over time.",
      "gridPos": { "x": 16, "y": 18, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(ingestion_documents_total[10m])) by (status)",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*failed.*" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*success.*" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "id": 10,
      "type": "row",
      "title": "Silent Failure Modes (PostgreSQL)",
      "gridPos": { "x": 0, "y": 26, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 11,
      "title": "Retry Storm — Documents by Attempt Count",
      "type": "barchart",
      "description": "Documents hitting 3+ attempts — silent failure mode not visible in Prometheus.",
      "gridPos": { "x": 0, "y": 27, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT ingest_attempt_count::text AS attempts, count(*) AS documents FROM documents GROUP BY ingest_attempt_count ORDER BY ingest_attempt_count;"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "xField": "attempts", "legend": { "showLegend": false } }
    },
    {
      "id": 12,
      "title": "Partial-Parse Rate",
      "type": "piechart",
      "description": "partial_success rate; Docling degradation.",
      "gridPos": { "x": 12, "y": 27, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [
        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COALESCE(parse_status, 'unknown') AS parse_status, count(*) AS documents FROM documents GROUP BY parse_status ORDER BY documents DESC;"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/^documents$/", "values": true }
      }
    },
    {
      "id": 13,
      "title": "Worker Error Logs",
      "type": "logs",
      "description": "Stack traces for failed tasks — Celery and ingestion/chat worker loggers at ERROR level.",
      "gridPos": { "x": 0, "y": 35, "w": 24, "h": 10 },
      "datasource": { "type": "elasticsearch", "uid": "elasticsearch" },
      "targets": [
        {
          "query": "level:ERROR AND (logger:celery* OR logger:src.services.* OR logger:src.observability.worker_metrics)",
          "metrics": [{ "id": "1", "type": "logs", "settings": { "limit": "500" } }],
          "bucketAggs": [],
          "timeField": "timestamp"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showTime": true,
        "showLabels": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      }
    }
  ]
}
