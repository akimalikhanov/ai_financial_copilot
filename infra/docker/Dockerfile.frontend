# syntax=docker/dockerfile:1
# ── Stage 1: Node build ────────────────────────────────────────────────────────
FROM node:22-slim AS builder

WORKDIR /app

# Install deps first (cache-friendly: only re-runs when package files change)
COPY src/ui/package.json src/ui/package-lock.json ./
# BuildKit cache mount persists npm's download cache across local rebuilds. Inert in CI
# (CI never builds this image). If a build job is added, use buildx cache on ephemeral runners.
RUN --mount=type=cache,target=/root/.npm \
    npm ci --ignore-scripts

# Copy the rest of the UI source and build.
# VITE_API_BASE_URL is baked into the bundle at build time. Default "/api" makes
# the client call same-origin /api/v1/..., which nginx proxies to the api service
# (the /api/ prefix is stripped by proxy_pass). Override via build arg if needed.
COPY src/ui/ ./
ARG VITE_API_BASE_URL=
ENV VITE_API_BASE_URL=${VITE_API_BASE_URL}
RUN npm run build
# Output lands in /app/dist

# ── Stage 2: nginx static server ───────────────────────────────────────────────
FROM nginx:1.27-alpine AS runtime

# Drop default nginx config; copy ours as a template for envsubst substitution at startup
RUN rm /etc/nginx/conf.d/default.conf
COPY src/ui/nginx.conf /etc/nginx/templates/app.conf.template

# Copy the built SPA
COPY --from=builder /app/dist /usr/share/nginx/html

EXPOSE 80

# Use 127.0.0.1, not localhost: in this image localhost resolves to ::1 (IPv6),
# but nginx listens on IPv4 0.0.0.0:80 only, so localhost would be refused.
HEALTHCHECK --interval=15s --timeout=5s --start-period=10s --retries=3 \
    CMD wget -qO- http://127.0.0.1/healthz || exit 1
