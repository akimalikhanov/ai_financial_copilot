{
  "index_patterns": ["copilot-logs-*"],
  "template": {
    "settings": {
      "index.lifecycle.name": "copilot-logs-ilm",
      "index.lifecycle.rollover_alias": "copilot-logs",
      "number_of_shards": 1,
      "number_of_replicas": 0
    },
    "mappings": {
      "properties": {
        "timestamp":    { "type": "date" },
        "level":        { "type": "keyword" },
        "logger":       { "type": "keyword" },
        "message":      { "type": "text" },
        "request_id":   { "type": "keyword" },
        "trace_id":     { "type": "keyword" },
        "method":       { "type": "keyword" },
        "path":         { "type": "keyword" },
        "http_status":  { "type": "integer" },
        "duration_ms":  { "type": "float" },
        "model_id":     { "type": "keyword" },
        "provider":     { "type": "keyword" }
      }
    }
  }
}
