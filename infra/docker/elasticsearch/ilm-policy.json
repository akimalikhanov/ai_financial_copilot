{
  "policy": {
    "phases": {
      "hot": {
        "actions": {
          "rollover": {
            "max_primary_shard_size": "5gb",
            "max_age": "1d",
            "min_docs": 1
          }
        }
      },
      "delete": {
        "min_age": "14d",
        "actions": { "delete": {} }
      }
    }
  }
}
