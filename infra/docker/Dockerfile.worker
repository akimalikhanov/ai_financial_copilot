# syntax=docker/dockerfile:1
# Shared image for chat worker and ingestion worker.
# Differentiated at runtime by CMD / entrypoint override in docker-compose.
#
# ── Stage 1: dependency builder ────────────────────────────────────────────────
FROM python:3.12-slim AS builder

WORKDIR /build

RUN pip install --no-cache-dir uv==0.8.19

COPY pyproject.toml uv.lock ./

# BuildKit cache mount: persists uv's wheel cache across local rebuilds so dep layers
# don't re-download when only pyproject/uv.lock change. Requires BuildKit (implied by the
# `# syntax=` directive on line 1). Inert in CI — CI never builds this image (it only lints
# the Dockerfile and runs tests on host Python). If an image-build job is ever added to CI,
# this mount no-ops on ephemeral runners; use buildx cache-from/cache-to there instead.
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-dev --group llm-engine --link-mode=copy

# ── Stage 2: runtime ────────────────────────────────────────────────────────────
FROM python:3.12-slim AS runtime

# Non-root user
RUN groupadd --gid 1001 appgroup && \
    useradd --uid 1001 --gid appgroup --no-create-home appuser

WORKDIR /app

# procps: celery inspect uses ps
# libxcb1 + libgl1: required by opencv-python (used by EasyOCR)
RUN apt-get update && apt-get install -y --no-install-recommends \
        procps \
        libxcb1 \
        libgl1 \
        libglib2.0-0 && \
    rm -rf /var/lib/apt/lists/*

COPY --from=builder /build/.venv /app/.venv

COPY src/ ./src/
COPY prompts/ ./prompts/
COPY infra/config/ ./infra/config/

RUN mkdir -p /tmp/prom_chat /tmp/prom_ingestion && \
    chown appuser /tmp/prom_chat /tmp/prom_ingestion

ENV PATH="/app/.venv/bin:$PATH" \
    PYTHONPATH="/app" \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PROJECT_ROOT="/app" \
    NVIDIA_VISIBLE_DEVICES=all \
    NVIDIA_DRIVER_CAPABILITIES=compute,utility

USER appuser

# ── Chat worker (default) ───────────────────────────────────────────────────────
# Override with: python -m src.workers.ingestion_worker
ENV PROMETHEUS_MULTIPROC_DIR=/tmp/prom_chat
CMD ["python", "-m", "src.workers.chat_worker"]
